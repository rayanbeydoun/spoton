# Copy this file to `.env.local` and fill in the values.

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- football-data.org (free token: https://www.football-data.org/client/register) ---
FOOTBALL_DATA_API_KEY=
# Competition code: PL = Premier League, WC = FIFA World Cup, EC = Euros, CL = Champions League
FOOTBALL_COMPETITION=PL

# --- App config ---
# Comma-separated emails allowed to open /admin and trigger fixture/result syncs.
ADMIN_EMAILS=you@example.com,brother@example.com
# Random secret string protecting the cron sync endpoint.
CRON_SECRET=change-me-to-a-long-random-string
# PL season to manage, as the starting year. 2025 = the 2025/26 season.
NEXT_PUBLIC_DEFAULT_SEASON=2025

# --- Web Push (phone reminder notifications) ---
# Generate a pair with: node -e "console.log(require('web-push').generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
